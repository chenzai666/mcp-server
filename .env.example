# ========== 基础配置 ==========
PORT=59795
# 不填则自动生成并持久化，首次启动后执行 docker compose logs mcp-server 查看
ADMIN_TOKEN=
REQUEST_TIMEOUT=20

# ========== 搜索配置 ==========
SEARXNG_URL=http://searxng:18080/search
SEARCH_BACKENDS=tavily,searxng,duckduckgo
TAVILY_API_KEY=your-tavily-api-key
TAVILY_TOPIC=general
SEARXNG_BASE_URL=http://localhost:18080/
SEARXNG_SECRET=your-searxng-secret

# ========== 可选增强 ==========
JINA_API_KEY=your-jina-api-key
OCR_LANG=eng+chi_sim
OCR_BACKEND=paddleocr
PADDLEOCR_LANG=ch

# 百度 OCR 配置（可选，设置后 OCR_BACKEND=baidu 时生效）
BAIDU_OCR_API_KEY=your-baidu-ocr-api-key
BAIDU_OCR_SECRET_KEY=your-baidu-ocr-secret-key

VISION_API_URL=
VISION_API_KEY=
GITHUB_TOKEN=
